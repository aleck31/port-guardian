{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PrefixListOwnAccount",
      "Effect": "Allow",
      "Action": [
        "ec2:GetManagedPrefixListEntries",
        "ec2:ModifyManagedPrefixList",
        "ec2:DescribeManagedPrefixLists"
      ],
      "Resource": "arn:aws:ec2:*:222829864634:prefix-list/pl-*",
      "Condition": {
        "StringEquals": {
          "ec2:ResourceTag/ManagedBy": "sg-guardian"
        }
      }
    },
    {
      "Sid": "PrefixListDescribeOwnAccount",
      "Effect": "Allow",
      "Action": "ec2:DescribeManagedPrefixLists",
      "Resource": "*"
    },
    {
      "Sid": "AssumeTargetRole",
      "Effect": "Allow",
      "Action": "sts:AssumeRole",
      "Resource": "arn:aws:iam::565521294060:role/sg-guardian-target-role"
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:*:222829864634:*"
    }
  ]
}
