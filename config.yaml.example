# EC2 SSH Guardian Configuration

accounts:
  primary:
    id: "222829864634"
    regions:
      - ap-southeast-1
      - ap-northeast-1
      - us-west-2
  secondary:
    id: "565521294060"
    role_arn: "arn:aws:iam::565521294060:role/ssh-guardian-target-role"
    regions:
      - ap-southeast-1
      - ap-northeast-1
      - us-west-2

cognito:
  region: ap-southeast-1
  user_pool_id: ap-southeast-1_WBHlZF1Zf
  client_id: npaahupnfnkpsfoov4hvm7ros

target_tag:
  key: ssh-guardian
  value: enabled

target_ports:
  - 22
  - 3389

max_entries: 20

lambda:
  deploy_region: ap-southeast-1
