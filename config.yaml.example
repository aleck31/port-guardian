# Port Guardian Configuration

accounts:
  primary:
    id: "111111111111"
    regions:
      - ap-southeast-1
      - ap-northeast-1
      - us-west-2
  secondary:
    id: "222222222222"
    role_arn: "arn:aws:iam::222222222222:role/port-guardian-target-role"
    regions:
      - ap-southeast-1
      - ap-northeast-1
      - us-west-2

cognito:
  region: ap-southeast-1
  user_pool_id: ap-southeast-1_XXXXXXXXX
  client_id: xxxxxxxxxxxxxxxxxxxxxxxxx

# SG management is driven by this tag. Its VALUE carries the ports per SG,
# e.g. `port-guardian=22,8443`. Add/remove ports or unmanage a SG by editing the tag.
target_tag:
  key: port-guardian

# Fallback ports only for a legacy bare tag value (`enabled`/empty). New SGs
# should always set explicit ports in the tag value instead.
target_ports:
  - 22
  - 3389

# FIFO eviction threshold (MAX_ENTRIES env) and MaxEntries for newly created PLs.
# Keep ≤ the real PL MaxEntries — if larger, adds fail with a mismatch error.
max_entries: 20

lambda:
  deploy_region: ap-southeast-1
